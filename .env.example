# Create a bot via @BotFather in Telegram and paste the token below
TELEGRAM_BOT_TOKEN=123456:ABC-DEF-your-token-here

# Send any message to your bot, then visit:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# to find your chat id
TELEGRAM_CHAT_ID=123456789

# Get a free 1000-credit API key at https://app.scrapingbee.com/account/register
# ScrapingBee does the anti-bot work that Yad2's ShieldSquare blocks otherwise.
SCRAPINGBEE_API_KEY=

# Optional overrides
# Smallest model that still produces text on Ollama (~91MB).
# Upgrade paths if summaries look broken:
#   smollm2:360m   (~230MB)
#   qwen2.5:0.5b   (~400MB, best quality-per-byte)
OLLAMA_MODEL=smollm2:135m
YAD2_URL=https://www.yad2.co.il/realestate/rent
SCRAPE_INTERVAL_MIN=60
JITTER_MIN=7

# Yad2 needs ScrapingBee stealth_proxy + render_js = 75 credits/call.
# 1000 free credits ≈ 13 hourly checks. Set SCRAPE_INTERVAL_MIN higher to stretch.
